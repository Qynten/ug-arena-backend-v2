generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(uuid())
  discordName      String?           @map("name")
  displayName      String?
  email            String            @unique
  password         String?
  refreshTokenHash String?
  photo            String?
  photoId          String?
  photoMedia       Media?            @relation("UserPhoto", fields: [photoId], references: [id])
  contactNO        String?
  location         String?
  status           UserStatus        @default(ACTIVE)
  roles            UserRole[]        @default([PLAYER])
  isBlocked        Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  disputeEvidence  DisputeEvidence[]
  disputeMessages  DisputeMessage[]
  disputesReported MatchDispute[]    @relation("ReportedBy")
  disputesResolved MatchDispute[]    @relation("ResolvedBy")

  participants            Participant[]            @relation("UserParticipants")
  teamPlayerRegistrations TeamPlayerRegistration[] @relation("PlayerTeamPlayerRegistrations")
  teamPlayer              TeamPlayer[]             @relation("PlayerTeam")
  tournamentRosters       TournamentRoster[]       @relation("UserRosters")
  ownedTournaments        Tournament[]             @relation("TournamentOwner")
  staffAssignments        TournamentStaff[]
  accounts                UserAccount[]
  notifications           Notification[]

  ownedParties     Party[]       @relation("PartyOwner")
  partyMemberships PartyMember[] @relation("PartyMemberships")
  partyInvites     PartyInvite[] @relation("PartyInvites")

  @@index([status])
  @@index([isBlocked])
  @@map("users")
}

model UserAccount {
  id                String       @id @default(uuid())
  userId            String
  provider          AuthProvider
  providerAccountId String       @unique
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  metadata          Json?        @default("{}")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("user_accounts")
}

model Tournament {
  id                 String               @id @default(uuid())
  slug               String               @unique @default(uuid())
  name               String
  description        String?
  game               String               @default("Chess")
  region             String               @default("Global")
  startTime          DateTime             @default(now())
  imageUrl           String?
  imageId            String?
  imageMedia         Media?               @relation("TournamentBanner", fields: [imageId], references: [id])
  type               TournamentType       @default(TEAM)
  bracketType        BracketType          @default(SINGLE_ELIMINATION)
  status             TournamentStatus     @default(DRAFT)
  regStart           DateTime?
  regEnd             DateTime?
  seedingStart       DateTime?
  seedingEnd         DateTime?
  liveStart          DateTime?
  liveEnd            DateTime?
  checkInStart       DateTime?
  checkInEnd         DateTime?
  maxParticipants    Int
  minTeamSize        Int                  @default(1)
  maxTeamSize        Int                  @default(5)
  bestOf             Int                  @default(1)
  allowDraws         Boolean              @default(false)
  allowSubstitutions Boolean              @default(false)
  logo               String?
  metadata           Json?                @default("{}")
  rules              String?
  requirements       String?
  isDeleted          Boolean              @default(false)
  ownerId            String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  auditLogs          AuditLog[]
  matchHistories     MatchHistory[]
  matches            Match[]
  participants       Participant[]        @relation("TournamentParticipants")
  prizePools         PrizePool[]
  rounds             Round[]              @relation("TournamentRounds")
  scores             score[]              @relation("TournamentScores")
  teams              Team[]               @relation("TournamentTeams")
  activities         TournamentActivity[]
  staff              TournamentStaff[]
  owner              User                 @relation("TournamentOwner", fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([status])
  @@index([name])
  @@index([game])
  @@index([region])
  @@index([game, region])
  @@index([isDeleted])
  @@map("tournaments")
}

model TournamentStaff {
  id           String             @id @default(uuid())
  userId       String
  tournamentId String
  role         TournamentRoleType
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId, role])
  @@index([userId])
  @@index([tournamentId])
  @@map("tournament_staff")
}

enum TournamentRoleType {
  DRAFT_ADMIN
  SEED_ADMIN
  SCORE_REPORTER
  MODERATOR
  TOURNAMENT_CREATOR
  DISPUTE_MANAGER
  TOURNAMENT_OVERSEER
}

model Participant {
  id                      String             @id @default(uuid())
  tournamentId            String
  userId                  String?
  teamId                  String?
  seed                    Int                @default(0)
  status                  ParticipantStatus  @default(REGISTERED)
  checkInStatus           CheckInStatus      @default(PENDING)
  points                  Float              @default(0)
  wins                    Int                @default(0)
  losses                  Int                @default(0)
  draws                   Int                @default(0)
  tiebreakerScore         Float              @default(0)
  buchholzScore           Float              @default(0)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  opponentHistories       MatchHistory[]     @relation("OpponentHistory")
  matchHistories          MatchHistory[]     @relation("ParticipantHistory")
  matchesAsP1             Match[]            @relation("MatchP1")
  matchesAsP2             Match[]            @relation("MatchP2")
  team                    Team?              @relation(fields: [teamId], references: [id])
  tournament              Tournament         @relation("TournamentParticipants", fields: [tournamentId], references: [id], onDelete: Cascade)
  user                    User?              @relation("UserParticipants", fields: [userId], references: [id])
  winnersOf               PrizePool[]
  firstParticipantScores  score[]            @relation("FirstParticipantScores")
  secondParticipantScores score[]            @relation("SecondParticipantScores")
  rosters                 TournamentRoster[]

  @@unique([tournamentId, userId])
  @@unique([tournamentId, teamId])
  @@index([tournamentId, status])
  @@index([tournamentId, checkInStatus])
  @@index([userId])
  @@index([teamId])
  @@map("participants")
}

model TournamentRoster {
  id            String         @id @default(uuid())
  participantId String
  userId        String
  role          TeamPlayerRole @default(MEMBER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  participant   Participant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  user          User           @relation("UserRosters", fields: [userId], references: [id])

  @@unique([participantId, userId])
  @@map("tournament_rosters")
}

model AuditLog {
  id            String     @id @default(uuid())
  tournamentId  String
  action        String
  payload       Json?
  snapshot      Json?
  performedById String?
  createdAt     DateTime   @default(now())
  tournament    Tournament @relation(fields: [tournamentId], references: [id])

  @@index([tournamentId])
  @@map("audit_logs")
}

model Team {
  id                      String                   @id @default(uuid())
  name                    String
  currentRoundId          String?
  tournamentId            String
  isDeleted               Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  participants            Participant[]
  teamPlayerRegistrations TeamPlayerRegistration[] @relation("TeamPlayerRegistrations")
  players                 TeamPlayer[]             @relation("TeamPlayers")
  tournament              Tournament               @relation("TournamentTeams", fields: [tournamentId], references: [id])

  @@index([tournamentId])
  @@index([isDeleted])
  @@map("teams")
}

model TeamPlayer {
  id        String         @id @default(uuid())
  role      TeamPlayerRole @default(MEMBER)
  joinedAt  DateTime       @default(now())
  teamId    String
  playerId  String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  player    User           @relation("PlayerTeam", fields: [playerId], references: [id])
  team      Team           @relation("TeamPlayers", fields: [teamId], references: [id])

  @@unique([teamId, playerId])
  @@index([teamId])
  @@index([playerId])
  @@map("team_players")
}

model TeamPlayerRegistration {
  id        String       @id @default(uuid())
  teamId    String
  playerId  String
  status    CommonStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  player    User         @relation("PlayerTeamPlayerRegistrations", fields: [playerId], references: [id])
  team      Team         @relation("TeamPlayerRegistrations", fields: [teamId], references: [id])

  @@index([teamId])
  @@index([playerId])
  @@map("team_player_registrations")
}

model Round {
  id             String         @id @default(uuid())
  name           Int            @default(1)
  tournamentId   String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  matchHistories MatchHistory[]
  matches        Match[]
  tournament     Tournament     @relation("TournamentRounds", fields: [tournamentId], references: [id])

  @@map("rounds")
}

model Match {
  id                 String         @id @default(uuid())
  tournamentId       String
  roundId            String
  participant1Id     String?
  participant2Id     String?
  p1Score            Int            @default(0)
  p2Score            Int            @default(0)
  status             MatchStatus    @default(PENDING)
  winnerId           String?
  draw               Boolean        @default(false)
  nextMatchId        String?
  loserMoveToMatchId String?
  branch             String?
  scheduledAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  disputes           MatchDispute[]
  matchHistories     MatchHistory[]
  sets               MatchSet[]
  participant1       Participant?   @relation("MatchP1", fields: [participant1Id], references: [id])
  participant2       Participant?   @relation("MatchP2", fields: [participant2Id], references: [id])
  round              Round          @relation(fields: [roundId], references: [id])
  tournament         Tournament     @relation(fields: [tournamentId], references: [id])

  @@index([tournamentId, status])
  @@index([participant1Id])
  @@index([participant2Id])
  @@map("matches")
}

model MatchSet {
  id          String   @id @default(uuid())
  matchId     String
  p1Score     Int
  p2Score     Int
  setNumber   Int
  evidenceUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@map("match_sets")
}

model MatchDispute {
  id           String            @id @default(uuid())
  matchId      String
  reportedById String
  status       DisputeStatus     @default(PENDING)
  resolution   String?
  resolvedById String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  evidence     DisputeEvidence[]
  messages     DisputeMessage[]
  match        Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  reportedBy   User              @relation("ReportedBy", fields: [reportedById], references: [id])
  resolvedBy   User?             @relation("ResolvedBy", fields: [resolvedById], references: [id])

  @@index([matchId])
  @@map("match_disputes")
}

model DisputeEvidence {
  id           String       @id @default(uuid())
  disputeId    String
  url          String
  type         EvidenceType @default(IMAGE)
  description  String?
  uploadedById String
  createdAt    DateTime     @default(now())
  dispute      MatchDispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])

  @@map("dispute_evidence")
}

model DisputeMessage {
  id        String       @id @default(uuid())
  disputeId String
  senderId  String
  content   String
  createdAt DateTime     @default(now())
  dispute   MatchDispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  sender    User         @relation(fields: [senderId], references: [id])

  @@map("dispute_messages")
}

model score {
  id                     String      @id @default(uuid())
  tournamentId           String
  firstParticipantId     String
  secondParticipantId    String
  firstParticipantScore  Int
  secondParticipantScore Int
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  firstParticipant       Participant @relation("FirstParticipantScores", fields: [firstParticipantId], references: [id])
  secondParticipant      Participant @relation("SecondParticipantScores", fields: [secondParticipantId], references: [id])
  tournament             Tournament  @relation("TournamentScores", fields: [tournamentId], references: [id])

  @@map("scores")
}

model TournamentActivity {
  id           String                 @id @default(uuid())
  type         TournamentActivityEnum
  tournamentId String
  description  String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  tournament   Tournament             @relation(fields: [tournamentId], references: [id])

  @@index([tournamentId])
  @@map("tournament_activities")
}

model MatchHistory {
  id               String      @id @default(uuid())
  participantId    String
  opponentId       String
  tournamentId     String
  roundId          String
  matchId          String
  participantScore Int
  opponentScore    Int
  result           MatchResult
  createdAt        DateTime    @default(now())
  match            Match       @relation(fields: [matchId], references: [id])
  opponent         Participant @relation("OpponentHistory", fields: [opponentId], references: [id])
  participant      Participant @relation("ParticipantHistory", fields: [participantId], references: [id])
  round            Round       @relation(fields: [roundId], references: [id])
  tournament       Tournament  @relation(fields: [tournamentId], references: [id])

  @@index([participantId])
  @@index([tournamentId])
  @@index([roundId])
  @@index([matchId])
  @@index([opponentId])
  @@map("match_history")
}

model PrizePool {
  id           String            @id @default(uuid())
  position     PrizePoolPosition
  amount       Float
  currency     String            @default("USD")
  tournamentId String
  winnerId     String?
  payoutStatus PayoutStatus      @default(PENDING)
  metadata     Json?             @default("{}")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tournament   Tournament        @relation(fields: [tournamentId], references: [id])
  winner       Participant?      @relation(fields: [winnerId], references: [id])

  @@map("prize_pools")
}

enum CommonStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum UserRole {
  PLAYER
  OWNER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AuthProvider {
  DISCORD
}

enum TournamentStatus {
  DRAFT
  REGISTRATION
  SEEDING
  LIVE
  COMPLETED
  CANCELLED
}

enum TournamentType {
  SOLO
  TEAM
}

enum BracketType {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  SWISS
  ROUND_ROBIN
}

enum CheckInStatus {
  PENDING
  CHECKED_IN
  ABSENT
  DISQUALIFIED
}

enum ParticipantStatus {
  REGISTERED
  DISQUALIFIED
  CANCELLED
}

enum DisputeStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum EvidenceType {
  IMAGE
  VIDEO
  DOCUMENT
  OTHER
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  CANCELLED
}

enum TeamPlayerRole {
  CAPTAIN
  MEMBER
}

enum MatchStatus {
  PENDING
  ONGOING
  COMPLETED
  DISPUTED
}

enum MatchResult {
  WIN
  LOSS
  DRAW
}

enum TournamentActivityEnum {
  TOURNAMENT_CREATE
  TEAM_REQUEST
  TEAM_ACCEPTED
  TEAM_REQUEST_REJECTED
  PLAYER_INVITED_TO_TEAM
  PLAYER_REMOVED_FROM_TEAM
  PLAYER_JOINED
  PLAYER_DECLINE
  SCORE_UPDATE
  MATCH_UPDATE
  PARTICIPANT_DISQUALIFIED
}

enum PrizePoolPosition {
  FIRST
  SECOND
  THIRD
  FOURTH
  FIFTH
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  payload   Json?            @default("{}")
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  TEAM_INVITE
  TOURNAMENT_UPDATE
  PARTY_INVITE
}

model Party {
  id        String        @id @default(uuid())
  name      String
  ownerId   String
  owner     User          @relation("PartyOwner", fields: [ownerId], references: [id])
  members   PartyMember[]
  invites   PartyInvite[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("parties")
}

model PartyMember {
  id        String         @id @default(uuid())
  partyId   String
  userId    String
  role      TeamPlayerRole @default(MEMBER)
  party     Party          @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user      User           @relation("PartyMemberships", fields: [userId], references: [id])
  createdAt DateTime       @default(now())

  @@unique([partyId, userId])
  @@map("party_members")
}

model PartyInvite {
  id        String       @id @default(uuid())
  partyId   String
  userId    String
  status    CommonStatus @default(PENDING)
  party     Party        @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user      User         @relation("PartyInvites", fields: [userId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([partyId, userId])
  @@map("party_invites")
}

model Media {
  id        String   @id @default(uuid())
  content   Bytes
  mimeType  String
  fileName  String?
  createdAt DateTime @default(now())

  tournaments Tournament[] @relation("TournamentBanner")
  users       User[]       @relation("UserPhoto")

  @@map("media")
}
